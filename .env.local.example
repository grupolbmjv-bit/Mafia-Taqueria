# ============================================================
# GastroCore — Variables de entorno
# Copia este archivo como .env.local y completa los valores.
# En Vercel: Settings -> Environment Variables (NO subir valores reales al repo).
# ============================================================

# URL de la Web App de Google Apps Script (termina en /exec)
GASTROCORE_API_URL=

# Token secreto de la API (SOLO en el servidor, nunca expuesto al navegador)
GASTROCORE_API_TOKEN=
